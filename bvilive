def load_bvi_config(path: str = ".bvi") -> dict:
    """Parse a .bvi key=value config file, mirroring bvi.cpp's loadConfig()."""
    cfg: dict = {}
    try:
        with open(path, encoding="utf-8-sig") as fh:
            for line in fh:
                line = line.rstrip("\r\n")
                line = line.lstrip(" \t")
                if not line or line.startswith("#"):
                    continue
                eq = line.find("=")
                if eq == -1:
                    continue
                key = line[:eq].rstrip(" \t")
                val = line[eq + 1:].lstrip(" \t")
                if key:
                    cfg[key] = val
    except FileNotFoundError:
        pass
    return cfg


