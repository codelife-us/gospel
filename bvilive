def find_bvilive_path() -> str:
    """Return the .bvilive path to use: local if present, else $HOME if present, else local."""
    local = ".bvilive"
    if os.path.exists(local):
        return local
    home = os.path.join(os.path.expanduser("~"), ".bvilive")
    if os.path.exists(home):
        return home
    return local


def load_bvilive_state(path: str) -> dict:
    """Parse .bvilive → {last_ref, default_theme, themes:{name:{key:val}}}."""
    state: dict = {"last_ref": "", "default_theme": "", "themes": {}}
    try:
        with open(path, encoding="utf-8-sig") as fh:
            current: str | None = None
            for line in fh:
                line = line.rstrip("\r\n").lstrip(" \t")
                if not line or line.startswith("#"):
                    continue
                m = re.match(r'^\[theme:(.+)\]$', line)
                if m:
                    current = m.group(1)
                    state["themes"].setdefault(current, {})
                    continue
                eq = line.find("=")
                if eq == -1:
                    continue
                key = line[:eq].rstrip(" \t")
                val = line[eq + 1:].lstrip(" \t")
                if current is None:
                    if key in ("last_ref", "default_theme", "half_size"):
                        state[key] = val
                else:
                    state["themes"][current][key] = val
    except FileNotFoundError:
        pass
    return state


def save_bvilive_state(path: str, state: dict):
    """Write .bvilive from state dict."""
    lines = ["# bvilive state\n"]
    if state.get("last_ref"):
        lines.append(f"last_ref = {state['last_ref']}\n")
    if state.get("default_theme"):
        lines.append(f"default_theme = {state['default_theme']}\n")
    if "half_size" in state:
        lines.append(f"half_size = {state['half_size']}\n")
    for name in sorted(state["themes"]):
        lines.append(f"\n[theme:{name}]\n")
        for k, v in state["themes"][name].items():
            lines.append(f"{k} = {v}\n")
    with open(path, "w", encoding="utf-8") as fh:
        fh.writelines(lines)


def load_verse_index(bible_dir: Path, filename: str) -> dict:
    """Return {book: {chapter: max_verse}} from a Bible text file."""
    index: dict = {}
    path = bible_dir / filename
    if not path.exists():
        return index
    with open(path, encoding="utf-8-sig") as fh:
        for line in fh:
            line = line.rstrip("\n")
            if "\t" not in line:
                continue
            ref = line.split("\t")[0]
            m = re.match(r'^(.+?)\s+(\d+):(\d+)$', ref)
            if not m:
                continue
            book, ch, vs = m.group(1), int(m.group(2)), int(m.group(3))
            index.setdefault(book, {}).setdefault(ch, 0)
            if vs > index[book][ch]:
                index[book][ch] = vs
    return index


